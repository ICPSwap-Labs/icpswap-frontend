    "bignumber.js": "^9.0.1",
    "copy-to-clipboard": "^3.2.0",
    "dayjs": "^1.11.10",
    "echarts": "^6.0.0",
    "i18next": "23.10.0",
    "jotai": "^2.15.0",
    "jsbi": "^4.3.0",
    "lodash": "^4.17.21",
    "qs": "^6.9.4",
    "react": "18.2.0",
    "react-dom": "18.2.0",
    "react-i18next": "14.1.0",
